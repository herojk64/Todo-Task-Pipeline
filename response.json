/project/avatar/10423?size=medium"}},"description":{"type":"doc","version":1,"content":[{"type":"paragraph","content":[{"type":"text","text":"Define and organize incoming requests using "},{"type":"text","text":"request types","marks":[{"type":"strong"}]},{"type":"text","text":". Capture and track relevant details upfront by customizing the "},{"type":"text","text":"request types","marks":[{"type":"strong"}]},{"type":"text","text":" you want to show up on the help center. You can also add "},{"type":"text","text":"internal fields","marks":[{"type":"strong"}]},{"type":"text","text":" to track details that you don't want your customers to see."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Try it out"}]},{"type":"paragraph","content":[{"type":"text","text":"We've given you some request types to try. Visit "},{"type":"text","text":"Channels","marks":[{"type":"strong"}]},{"type":"text","text":" (you may need to click "},{"type":"text","text":"Back to space","marks":[{"type":"strong"}]},{"type":"text","text":" to get out of your queues menu) to raise a request via your service space's Help Center and see them in action."}]}]},"status":{"self":"https://herojk64.atlassian.net/rest/api/3/status/10007","description":"This was auto-generated by Jira Service Management during workflow import","iconUrl":"https://herojk64.atlassian.net/images/icons/statuses/generic.png","name":"Waiting for approval","id":"10007","statusCategory":{"self":"https://herojk64.atlassian.net/rest/api/3/statuscategory/2","id":2,"key":"new","colorName":"blue-gray","name":"To Do"}}}},{"expand":"renderedFields,names,schema,operations,editmeta,changelog,versionedRepresentations","id":"10002","self":"https://herojk64.atlassian.net/rest/api/3/issue/10002","key":"DEMO-3","fields":{"summary":"Agents & customers","project":{"self":"https://herojk64.atlassian.net/rest/api/3/project/10000","id":"10000","key":"DEMO","name":"Demo service space","projectTypeKey":"service_desk","simplified":false,"avatarUrls":{"48x48":"https://herojk64.atlassian.net/rest/api/3/universal_avatar/view/type/project/avatar/10423","24x24":"https://herojk64.atlassian.net/rest/api/3/universal_avatar/view/type/project/avatar/10423?size=small","16x16":"https://herojk64.atlassian.net/rest/api/3/universal_avatar/view/type/project/avatar/10423?size=xsmall","32x32":"https://herojk64.atlassian.net/rest/api/3/universal_avatar/view/type/project/avatar/10423?size=medium"}},"description":{"type":"doc","version":1,"content":[{"type":"paragraph","content":[{"type":"text","text":"Agents","marks":[{"type":"strong"}]},{"type":"text","text":" are the members of your team that answer and resolve requests from your "},{"type":"text","text":"Customers","marks":[{"type":"strong"}]},{"type":"text","text":". In Jira Service Management, you only pay for agents and not the customers who raise requests. In other words, you can support as many customers as you need without paying any extra."}]},{"type":"paragraph","content":[{"type":"text","text":"Ready to invite your team? Look for "},{"type":"text","text":"Invite team","marks":[{"type":"strong"}]},{"type":"text","text":" on your space's sidebar (you may need to select "},{"type":"text","text":"Back to space","marks":[{"type":"strong"}]},{"type":"text","text":" to get out of your queues menu) to invite your team as agents."}]}]},"status":{"self":"https://herojk64.atlassian.net/rest/api/3/status/10002","description":"This was auto-generated by Jira Service Management during workflow import","iconUrl":"https://herojk64.atlassian.net/images/icons/statuses/generic.png","name":"Waiting for support","id":"10002","statusCategory":{"self":"https://herojk64.atlassian.net/rest/api/3/statuscategory/4","id":4,"key":"indeterminate","colorName":"yellow","name":"In Progress"}}}},{"expand":"renderedFields,names,schema,operations,editmeta,changelog,versionedRepresentations","id":"10001","self":"https://herojk64.atlassian.net/rest/api/3/issue/10001","key":"DEMO-2","fields":{"summary":"Capturing customer email requests","project":{"self":"https://herojk64.atlassian.net/rest/api/3/project/10000","id":"10000","key":"DEMO","name":"Demo service space","projectTypeKey":"service_desk","simplified":false,"avatarUrls":{"48x48":"https://herojk64.atlassian.net/rest/api/3/universal_avatar/view/type/project/avatar/10423","24x24":"https://herojk64.atlassian.net/rest/api/3/universal_avatar/view/type/project/avatar/10423?size=small","16x16":"https://herojk64.atlassian.net/rest/api/3/universal_avatar/view/type/project/avatar/10423?size=xsmall","32x32":"https://herojk64.atlassian.net/rest/api/3/universal_avatar/view/type/project/avatar/10423?size=medium"}},"description":{"type":"doc","version":1,"content":[{"type":"paragraph","content":[{"type":"text","text":"The easiest way for your customer's to request help is by sending an email to your service space. When emails get sent to your space, they land in your queue as a request (just like this one)."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Try it out"}]},{"type":"paragraph","content":[{"type":"text","text":"Email a request to "},{"type":"text","text":"Demo service space's","marks":[{"type":"strong"}]},{"type":"text","text":" support email address ( "},{"type":"text","text":"demo@herojk64.atlassian.net","marks":[{"type":"link","attrs":{"href":"mailto:demo@herojk64.atlassian.net"}}]},{"type":"text","text":" ) to see how it looks for your customers and agents."}]}]},"status":{"self":"https://herojk64.atlassian.net/rest/api/3/status/10002","description":"This was auto-generated by Jira Service Management during workflow import","iconUrl":"https://herojk64.atlassian.net/images/icons/statuses/generic.png","name":"Waiting for support","id":"10002","statusCategory":{"self":"https://herojk64.atlassian.net/rest/api/3/statuscategory/4","id":4,"key":"indeterminate","colorName":"yellow","name":"In Progress"}}}},{"expand":"renderedFields,names,schema,operations,editmeta,changelog,versionedRepresentations","id":"10000","self":"https://herojk64.atlassian.net/rest/api/3/issue/10000","key":"DEMO-1","fields":{"summary":"What is a request?","project":{"self":"https://herojk64.atlassian.net/rest/api/3/project/10000","id":"10000","key":"DEMO","name":"Demo service space","projectTypeKey":"service_desk","simplified":false,"avatarUrls":{"48x48":"https://herojk64.atlassian.net/rest/api/3/universal_avatar/view/type/project/avatar/10423","24x24":"https://herojk64.atlassian.net/rest/api/3/universal_avatar/view/type/project/avatar/10423?size=small","16x16":"https://herojk64.atlassian.net/rest/api/3/universal_avatar/view/type/project/avatar/10423?size=xsmall","32x32":"https://herojk64.atlassian.net/rest/api/3/universal_avatar/view/type/project/avatar/10423?size=medium"}},"description":{"type":"doc","version":1,"content":[{"type":"paragraph","content":[{"type":"text","text":"Requests are like emails from your customers asking for help. Like email, you can respond to the reporter and add attachments. Unlike email, you can set all kinds of useful information, such as labels, priority and a status showing where the request is up to."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Try it out"}]},{"type":"paragraph","content":[{"type":"text","text":"When you've finished exploring this request, "},{"type":"text","text":"update the status","marks":[{"type":"strong"}]},{"type":"text","text":" to resolve it and let the reporter know it's done."}]}]},"status":{"self":"https://herojk64.atlassian.net/rest/api/3/status/10002","description":"This was auto-generated by Jira Service Management during workflow import","iconUrl":"https://herojk64.atlassian.net/images/icons/statuses/generic.png","name":"Waiting for support","id":"10002","statusCategory":{"self":"https://herojk64.atlassian.net/rest/api/3/statuscategory/4","id":4,"key":"indeterminate","colorName":"yellow","name":"In Progress"}}}}],"isLast":true}
